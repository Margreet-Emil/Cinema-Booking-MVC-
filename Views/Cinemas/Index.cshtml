@model IEnumerable<CinemaBookingSystem.Models.Cinema>

@{
    ViewData["Title"] = "Cinemas";
}

<h2>Our Cinemas</h2>

<div class="row">
    @foreach (var cinema in Model)
    {
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@cinema.Name</h5>
                    <p class="card-text text-muted">@cinema.Address</p>

                    <h6>Halls:</h6>
                    <ul>
                        @foreach (var hall in cinema.Halls)
                        {
                            <li>@hall.Name — @hall.SeatCapacity seats</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <p class="text-muted">No cinemas available yet.</p>
}