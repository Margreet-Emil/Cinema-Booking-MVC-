@model IEnumerable<CinemaBookingSystem.Models.Booking>

@{
    ViewData["Title"] = "My Bookings";
}

<h2>My Bookings</h2>

@if (!Model.Any())
{
    <p class="text-muted">You have no bookings yet.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Movie</th>
                <th>Cinema / Hall</th>
                <th>Showtime</th>
                <th>Seats</th>
                <th>Total Price</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model)
            {
                <tr>
                    <td>@booking.Showtime?.Movie?.Title</td>
                    <td>@booking.Showtime?.Hall?.Cinema?.Name / @booking.Showtime?.Hall?.Name</td>
                    <td>@booking.Showtime?.StartTime.ToString("dd MMM yyyy, hh:mm tt")</td>
                    <td>@booking.NumberOfSeats</td>
                    <td>@booking.TotalPrice.ToString("C")</td>
                    <td>
                        @if (booking.Status == CinemaBookingSystem.Models.BookingStatus.Cancelled)
                        {
                            <span class="badge bg-secondary">Cancelled</span>
                        }
                        else if (booking.Showtime != null && booking.Showtime.StartTime <= DateTime.Now)
                        {
                            <span class="badge bg-success">Completed</span>
                        }
                        else
                        {
                            <span class="badge bg-primary">Upcoming</span>
                        }
                    </td>
                    <td>
                        @if (booking.Status == CinemaBookingSystem.Models.BookingStatus.Confirmed
                             && booking.Showtime != null && booking.Showtime.StartTime > DateTime.Now)
                        {
                            <form asp-action="Cancel" asp-route-id="@booking.Id" method="post"
                                  onsubmit="return confirm('Are you sure you want to cancel this booking?');">
                                <button type="submit" class="btn btn-sm btn-danger">Cancel</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}