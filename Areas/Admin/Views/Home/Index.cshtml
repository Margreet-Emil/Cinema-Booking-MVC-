@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2>Admin Dashboard</h2>

<div class="row mt-4">
    <div class="col-md-2 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h3>@ViewBag.MoviesCount</h3>
                <p class="text-muted mb-0">Movies</p>
            </div>
        </div>
    </div>
    <div class="col-md-2 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h3>@ViewBag.CinemasCount</h3>
                <p class="text-muted mb-0">Cinemas</p>
            </div>
        </div>
    </div>
    <div class="col-md-2 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h3>@ViewBag.HallsCount</h3>
                <p class="text-muted mb-0">Halls</p>
            </div>
        </div>
    </div>
    <div class="col-md-2 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h3>@ViewBag.ShowtimesCount</h3>
                <p class="text-muted mb-0">Showtimes</p>
            </div>
        </div>
    </div>
    <div class="col-md-2 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h3>@ViewBag.BookingsCount</h3>
                <p class="text-muted mb-0">Bookings</p>
            </div>
        </div>
    </div>
</div>

<h4 class="mt-4">Manage</h4>
<div class="list-group col-md-4">
    <a asp-controller="Categories" asp-action="Index" class="list-group-item list-group-item-action">Categories</a>
    <a asp-controller="Cinemas" asp-action="Index" class="list-group-item list-group-item-action">Cinemas</a>
    <a asp-controller="Halls" asp-action="Index" class="list-group-item list-group-item-action">Halls</a>
    <a asp-controller="Movies" asp-action="Index" class="list-group-item list-group-item-action">Movies</a>
    <a asp-controller="Showtimes" asp-action="Index" class="list-group-item list-group-item-action">Showtimes</a>
    <a asp-action="Bookings" class="list-group-item list-group-item-action">All Bookings</a>
</div>