@model IEnumerable<CinemaBookingSystem.Models.Booking>

@{
    ViewData["Title"] = "All Bookings";
}

<h2>All Bookings</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Customer</th>
            <th>Movie</th>
            <th>Cinema / Hall</th>
            <th>Showtime</th>
            <th>Seats</th>
            <th>Total Price</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var booking in Model)
        {
            <tr>
                <td>@booking.User?.FullName (@booking.User?.Email)</td>
                <td>@booking.Showtime?.Movie?.Title</td>
                <td>@booking.Showtime?.Hall?.Cinema?.Name / @booking.Showtime?.Hall?.Name</td>
                <td>@booking.Showtime?.StartTime.ToString("dd MMM yyyy, hh:mm tt")</td>
                <td>@booking.NumberOfSeats</td>
                <td>@booking.TotalPrice.ToString("C")</td>
                <td>
                    @if (booking.Status == CinemaBookingSystem.Models.BookingStatus.Cancelled)
                    {
                        <span class="badge bg-secondary">Cancelled</span>
                    }
                    else
                    {
                        <span class="badge bg-primary">Confirmed</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted">No bookings yet.</p>
}