@model CinemaBookingSystem.Models.Hall

@{
    ViewData["Title"] = "Add Hall";
}

<h2>Add Hall</h2>

<form asp-action="Create" method="post" class="col-md-6">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group mb-3">
        <label asp-for="CinemaId" class="control-label">Cinema</label>
        <select asp-for="CinemaId" asp-items="ViewBag.Cinemas" class="form-control">
            <option value="">-- Select Cinema --</option>
        </select>
        <span asp-validation-for="CinemaId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Name" class="control-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="SeatCapacity" class="control-label"></label>
        <input asp-for="SeatCapacity" class="form-control" />
        <span asp-validation-for="SeatCapacity" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}